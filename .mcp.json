{
  "mcpServers": {
    "kubernetes": {
      "command": "kubernetes-mcp-server",
      "args": [],
      "env": {
        "KUBECONFIG": "contexts/local/.kube/config"
      }
    },
    "grafana": {
      "command": "scripts/mcp-grafana-wrapper.sh",
      "args": ["-t", "stdio", "-tls-skip-verify"],
      "env": {
        "GRAFANA_URL": "${GRAFANA_URL:-}",
        "GRAFANA_USERNAME": "${GRAFANA_USERNAME:-admin}",
        "GRAFANA_PASSWORD": "${GRAFANA_PASSWORD:-grafana}"
      }
    }
  }
}
